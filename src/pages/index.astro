---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_KEYWORDS } from '../consts';

const methodCards = [
	{
		title: 'Urval av produkter',
		text: 'Vi tar med produkter som köpare faktiskt ställer mot varandra: etablerade favoriter, nya utmanare och modeller i samma användningsområde.',
	},
	{
		title: 'Kontroll av uppgifter',
		text: 'Tekniska data, priser och villkor jämförs mot flera öppna källor innan de hamnar i våra sammanställningar.',
	},
	{
		title: 'Fokus på vardagen',
		text: 'Tyngdpunkten ligger på sådant du märker efter köpet: installation, skötsel, ljud, tillbehör och hur smidigt allt fungerar hemma.',
	},
	{
		title: 'Enkel slutsats',
		text: 'Vi försöker landa i en rak rekommendation och samtidigt vara tydliga med när ett annat val kan passa bättre.',
	},
];

const expectations = [
	{
		title: 'Tydliga prioriteringar',
		text: 'Vi visar vilka funktioner som faktiskt påverkar användningen och vilka som mest låter bra i en annons.',
	},
	{
		title: 'Uppdaterad kontext',
		text: 'När prisbild, lagerstatus eller nya modeller ändras behöver även rekommendationen kunna ändras.',
	},
	{
		title: 'Ärlig avgränsning',
		text: 'Om en guide inte täcker ett visst behov säger vi det hellre än att låtsas att den passar alla.',
	},
];
---

<!doctype html>
<html lang="sv">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} keywords={SITE_KEYWORDS} />
	</head>
	<body>
		<Header />
		<main>
			<section class="home-hero">
				<div class="container">
					<p class="eyebrow">Om hushustest</p>
					<h1>Enklare väg till rätt produktval</h1>
					<p>
						hushustest hjälper dig att snabbt se skillnaden mellan produkter inom hemteknik och
						vardag. Vi lyfter fram vad som är värt pengarna, vilka detaljer som spelar roll och
						vilka begränsningar du bör känna till före köp.
					</p>
				</div>
			</section>

			<section class="section soft">
				<div class="container">
					<h2>Så tar vi fram våra jämförelser</h2>
					<div class="method-grid">
						{
							methodCards.map((card) => (
								<article class="home-card card">
									<h3>{card.title}</h3>
									<p>{card.text}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="section">
				<div class="container">
					<div class="section-copy">
						<h2>Så väger vi ihop resultatet</h2>
						<p>
							Ett högt betyg handlar inte bara om en stark specifikation. Vi tittar på pris,
							funktion, användarvänlighet, servicebehov och om fördelarna faktiskt märks i ett
							vanligt hem.
						</p>
						<ul class="tiny-list">
							<li>Varje rekommendation ska gå att koppla till tydliga skillnader</li>
							<li>Pris bedöms mot nytta, byggkvalitet och förväntad livslängd</li>
							<li>Osäkra uppgifter lämnas öppna i stället för att fyllas med gissningar</li>
						</ul>
					</div>
				</div>
			</section>

			<section class="section soft">
				<div class="container">
					<div class="section-copy">
						<h2>Vad du får av våra guider</h2>
						<p>
							Guiderna är skrivna för dig som vill komma vidare utan att läsa varje datablad
							själv. Tonen ska vara praktisk, kontrollerbar och tydlig nog för ett riktigt
							köpbeslut.
						</p>
					</div>
					<div class="expect-grid">
						{
							expectations.map((card) => (
								<article class="home-card card">
									<h3>{card.title}</h3>
									<p>{card.text}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="section">
				<div class="container">
					<h2>Senaste jämförelse</h2>
					<a class="latest-card card" href="/robotdammsugarna-2026-test/">
						<h3>Bästa robotdammsugaren 2026</h3>
						<p>
							Vi jämför 7 robotdammsugare utifrån pris, batteritid, navigering, moppning och hur
							de fungerar i ett vanligt hem.
						</p>
						<span>Läs testet</span>
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.home-hero {
		padding: 108px 0 92px;
	}

	.home-hero .container {
		margin-left: auto;
		margin-right: auto;
	}

	.home-hero h1 {
		margin: 7px 0 18px;
		max-width: 560px;
	}

	.home-hero p:not(.eyebrow) {
		max-width: 560px;
	}

	.section h2 {
		margin-bottom: 22px;
	}

	.method-grid {
		display: grid;
		gap: 18px;
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.expect-grid {
		display: grid;
		gap: 18px;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		margin-top: 26px;
	}

	.home-card {
		min-height: 92px;
		padding: 18px 20px;
	}

	.home-card h3 {
		font-size: 13px;
		margin-bottom: 8px;
	}

	.home-card p {
		font-size: 12px;
		line-height: 1.65;
	}

	.section-copy {
		max-width: 760px;
	}

	.section-copy h2 {
		margin-bottom: 18px;
	}

	.section-copy p {
		margin-bottom: 18px;
	}

	.tiny-list {
		color: var(--muted);
		font-size: 12px;
		line-height: 1.9;
	}

	.tiny-list li::marker {
		color: var(--blue);
	}

	.latest-card {
		display: block;
		margin-top: 24px;
		max-width: 400px;
		padding: 20px 22px;
	}

	.latest-card h3 {
		font-size: 14px;
		margin-bottom: 9px;
	}

	.latest-card p {
		font-size: 12px;
		line-height: 1.7;
	}

	.latest-card span {
		color: var(--blue-dark);
		display: inline-block;
		font-size: 12px;
		font-weight: 800;
		margin-top: 10px;
	}

	@media (max-width: 680px) {
		.method-grid,
		.expect-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
