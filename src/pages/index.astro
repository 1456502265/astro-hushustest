---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_KEYWORDS } from '../consts';

const methodCards = [
	{
		title: 'Produkter som faktiskt jämförs',
		text: 'Vi utgår från modeller som ofta hamnar på samma inköpslista: välkända alternativ, nya uppstickare och produkter i liknande prisklass.',
	},
	{
		title: 'Fakta från flera håll',
		text: 'Specifikationer, priser och villkor stäms av mot öppna källor så att guiden inte lutar sig mot en enda butikssida.',
	},
	{
		title: 'Det som märks hemma',
		text: 'Vi lägger störst vikt vid sådant som påverkar vardagen: installation, ljudnivå, underhåll, reservdelar och hur enkelt produkten är att använda.',
	},
	{
		title: 'En tydlig rekommendation',
		text: 'Målet är att ge ett konkret råd, men också att säga när produkten inte är rätt val för vissa behov.',
	},
];

const expectations = [
	{
		title: 'Prioriteringar som går att förstå',
		text: 'Vi förklarar varför en funktion är viktig och när den mest är något som ser bra ut i marknadsföringen.',
	},
	{
		title: 'Pris och läge vägs in',
		text: 'En bra produkt kan bli mindre intressant om priset ändras, och ett enklare val kan bli starkare vid rätt kampanj.',
	},
	{
		title: 'Tydliga avgränsningar',
		text: 'Om en jämförelse inte svarar på ett specialbehov skriver vi det rakt ut i stället för att göra guiden bredare än den är.',
	},
];
---

<!doctype html>
<html lang="sv">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} keywords={SITE_KEYWORDS} />
	</head>
	<body>
		<Header />
		<main>
			<section class="home-hero">
				<div class="container">
					<p class="eyebrow">Om hushustest</p>
					<h1>Tryggare val när du jämför produkter</h1>
					<p>
						hushustest gör det lättare att sålla bland hemteknik och vardagsprodukter. Vi lyfter
						fram skillnaderna som spelar roll, vad som är rimligt att betala för och vilka
						kompromisser som är bra att känna till innan du beställer.
					</p>
				</div>
			</section>

			<section class="section soft">
				<div class="container">
					<h2>Så arbetar vi med våra jämförelser</h2>
					<div class="method-grid">
						{
							methodCards.map((card) => (
								<article class="home-card card">
									<h3>{card.title}</h3>
									<p>{card.text}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="section">
				<div class="container">
					<div class="section-copy">
						<h2>Så bedömer vi helheten</h2>
						<p>
							Ett bra köp avgörs sällan av en enda specifikation. Därför väger vi samman pris,
							prestanda, användarvänlighet, skötsel och hur stor nytta produkten faktiskt gör i
							ett vanligt hem.
						</p>
						<ul class="tiny-list">
							<li>Rekommendationer ska bygga på konkreta skillnader, inte magkänsla</li>
							<li>Priset sätts i relation till nytta, kvalitet och förväntad hållbarhet</li>
							<li>Oklara uppgifter markeras hellre än fylls ut med antaganden</li>
						</ul>
					</div>
				</div>
			</section>

			<section class="section soft">
				<div class="container">
					<div class="section-copy">
						<h2>Vad guiderna ska hjälpa dig med</h2>
						<p>
							Vi skriver för dig som vill komma vidare i valet utan att läsa igenom varje
							datablad själv. Språket ska vara rakt, praktiskt och lätt att kontrollera mot
							egna behov.
						</p>
					</div>
					<div class="expect-grid">
						{
							expectations.map((card) => (
								<article class="home-card card">
									<h3>{card.title}</h3>
									<p>{card.text}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="section">
				<div class="container">
					<h2>Senaste jämförelse</h2>
					<a class="latest-card card" href="/robotdammsugarna-2026-test/">
						<h3>Bästa robotdammsugaren 2026</h3>
						<p>
							En genomgång av 7 robotdammsugare där pris, batteritid, navigering, moppning och
							vardaglig användning vägs samman.
						</p>
						<span>Läs testet</span>
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.home-hero {
		padding: 108px 0 92px;
	}

	.home-hero .container {
		margin-left: auto;
		margin-right: auto;
	}

	.home-hero h1 {
		margin: 7px 0 18px;
		max-width: 560px;
	}

	.home-hero p:not(.eyebrow) {
		max-width: 560px;
	}

	.section h2 {
		margin-bottom: 22px;
	}

	.method-grid {
		display: grid;
		gap: 18px;
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.expect-grid {
		display: grid;
		gap: 18px;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		margin-top: 26px;
	}

	.home-card {
		min-height: 92px;
		padding: 18px 20px;
	}

	.home-card h3 {
		font-size: 13px;
		margin-bottom: 8px;
	}

	.home-card p {
		font-size: 12px;
		line-height: 1.65;
	}

	.section-copy {
		max-width: 760px;
	}

	.section-copy h2 {
		margin-bottom: 18px;
	}

	.section-copy p {
		margin-bottom: 18px;
	}

	.tiny-list {
		color: var(--muted);
		font-size: 12px;
		line-height: 1.9;
	}

	.tiny-list li::marker {
		color: var(--blue);
	}

	.latest-card {
		display: block;
		margin-top: 24px;
		max-width: 400px;
		padding: 20px 22px;
	}

	.latest-card h3 {
		font-size: 14px;
		margin-bottom: 9px;
	}

	.latest-card p {
		font-size: 12px;
		line-height: 1.7;
	}

	.latest-card span {
		color: var(--blue-dark);
		display: inline-block;
		font-size: 12px;
		font-weight: 800;
		margin-top: 10px;
	}

	@media (max-width: 680px) {
		.method-grid,
		.expect-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
