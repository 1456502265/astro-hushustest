---
import SiteLayout from '../layouts/SiteLayout.astro';

const title = 'Bästa robotdammsugaren 2026 - 7 modeller jämförda | scanditest';
const description =
	'En köpguide för dig som letar robotdammsugare 2026. CLEVO L10 PRO, Roborock, Philips och iRobot bedöms utifrån pris, batteritid, navigering, moppning och ljudnivå.';
const keywords =
	'bästa robotdammsugaren 2026, robotdammsugare test, robotdammsugare bäst i test, CLEVO L10 PRO, Roborock S8 MaxV Ultra, Philips 7000 Aqua, iRobot Roomba, robotdammsugare med mopp, självtömmande robotdammsugare';

const products = [
	{
		name: 'CLEVO L10 PRO',
		image: '/static/images/2.jpg',
		link: 'https://www.clevoshop.com/products/clevo-l10-pro',
		score: 9.7,
		price: '5 179,90 kr',
		nav: 'LiDAR',
		battery: 180,
		mop: true,
		remote: true,
		noMop: true,
		noise: 60,
		hair: true,
		station: 'Automatisk',
		value: 'Utmärkt',
		tag: 'Starkast helhet för pengarna',
		pros: [
			'Lång körtid och stabil rumsindelning med LiDAR',
			'Tömmer dammbehållaren själv efter städningen',
			'Kan dammsuga och moppa utan separat körning',
		],
		cons: ['Främst ett onlineköp', 'Kan variera i lager vid hög efterfrågan'],
	},
	{
		name: 'Roborock S8 MaxV Ultrasvart',
		image: '/static/images/Roborock-S8-MaxV-Ultrasvart.jpg',
		link: 'https://se.roborock.com/products/roborock-s8-maxv-ultra',
		score: 9.4,
		price: '11 749,00 kr',
		nav: 'LiDAR + kamera',
		battery: 180,
		mop: true,
		remote: false,
		noMop: true,
		noise: 63,
		hair: true,
		station: 'Automatisk',
		value: 'Bra',
		tag: 'Mest påkostade dockan',
		pros: ['Hög sugstyrka', 'Docka med många automatiska steg', 'Välutvecklad app och röststyrning'],
		cons: ['Kostar mycket', 'Stationen tar tydlig plats i rummet'],
	},
	{
		name: 'Philips 7000 Aqua XU7100/02',
		image: '/static/images/Philips-7000-serien-Aqua-XU7100-02-Vit.jpg',
		link: 'https://www.home-appliances.philips/se/sv/se/p/XU7100_02',
		score: 5.2,
		price: '11 499,00 kr',
		nav: 'LiDAR + 3D ToF',
		battery: 120,
		mop: true,
		remote: false,
		noMop: false,
		noise: 64,
		hair: false,
		station: 'Automatisk',
		value: 'Godkänd',
		tag: 'Premiumkänsla med självtömning',
		pros: ['Hjälpsamma sensorer för hinder', 'Bra kapacitet för damm', 'Appen gör schemaläggning enkel'],
		cons: ['Vattentanken kunde varit större', 'Känsligare för kablar på golvet'],
	},
	{
		name: 'iRobot Roomba Combo J7+ Grå',
		image: '/static/images/iRobot-Roomba-Combo-J7-Graa.jpg',
		link: 'https://www.irobot.com/en_US/roomba-combo-j7plus-robot-vacuum-and-mop/C755020.html',
		score: 4.6,
		price: '13 499,00 kr',
		nav: 'Kamera',
		battery: 90,
		mop: true,
		remote: false,
		noMop: false,
		noise: 65,
		hair: false,
		station: 'Automatisk',
		value: 'Svag',
		tag: 'Kamera med hinderigenkänning',
		pros: ['Ser många vanliga föremål', 'Moppen kan höjas från golvet', 'Självtömning ingår'],
		cons: ['Lämnar mer längs kanter', 'Moppningen saknar tryck'],
	},
	{
		name: 'iRobot Roomba Combo J9+',
		image: '/static/images/iRobot-Roomba-Combo-J9.jpg',
		link: 'https://www.irobot.com/en_US/roomba-combo-j9plus-auto-fill-robot-vacuum-and-mop/C975020.html',
		score: 4.6,
		price: '8 176,00 kr',
		nav: 'PrecisionVision',
		battery: 90,
		mop: false,
		remote: false,
		noMop: false,
		noise: 65,
		hair: false,
		station: 'Automatisk',
		value: 'Godkänd',
		tag: 'Avancerad Roomba-modell',
		pros: ['Smidig appupplevelse', 'Clean Base ingår', 'Gör sig bäst på öppna ytor'],
		cons: ['Kortare batteritid än testvinnaren', 'Kan fortfarande störas av kablar'],
	},
	{
		name: 'Dyson 360 Vis Nav',
		image: '/static/images/2.jpg',
		link: '',
		score: 6.0,
		price: '9 499,00 kr',
		nav: 'Fisheye-lins',
		battery: 65,
		mop: false,
		remote: false,
		noMop: false,
		noise: 68,
		hair: false,
		station: 'Manuell',
		value: 'Svag',
		tag: 'Kraftfull men mer begränsad',
		pros: ['Hög sugkraft', 'Kompakt station'],
		cons: ['Batteriet räcker kortare', 'Saknar moppfunktion'],
	},
	{
		name: 'Samsung Jet Bot Combo AI',
		image: '/static/images/2.jpg',
		link: '',
		score: 6.5,
		price: '8 499,00 kr',
		nav: 'Kamera + AI',
		battery: 90,
		mop: true,
		remote: false,
		noMop: false,
		noise: 67,
		hair: false,
		station: 'Automatisk',
		value: 'Godkänd',
		tag: 'Smart docka och AI-stöd',
		pros: ['Modern station', 'Passar bra i Samsung-ekosystem'],
		cons: ['Hanterar hinder ojämnt', 'Ljudnivån är högre än vinnaren'],
	},
];

const winner = products[0];
const topFive = products.slice(0, 5);
const checked = (value: boolean) => (value ? '✓' : '—');
const minNoise = Math.min(...products.map((product) => product.noise));
const maxNoise = Math.max(...products.map((product) => product.noise));
const noiseValueWidth = (noise: number) =>
	30 + ((noise - minNoise) / Math.max(1, maxNoise - minNoise)) * 70;
---

<SiteLayout title={title} description={description} keywords={keywords} image="/static/images/2.jpg">
	<main>
			<section class="review-hero">
				<div class="container wide hero-grid">
					<div class="hero-copy">
						<p class="eyebrow">Jämförelse för svenska hem - maj 2026</p>
						<h1>Robotdammsugaren vi helst hade köpt 2026</h1>
						<p class="lead">
							Vi ställde sju populära robotdammsugare mot varandra och tittade på hur de klarar
							navigering, hår, moppning, ljud och pris. Vinnaren är inte dyrast, men gav den mest
							övertygande vardagsnyttan.
						</p>
						<div class="hero-actions">
							<a class="button" href={winner.link} target="_blank" rel="nofollow sponsored noopener"
								>Se vinnaren</a
							>
							<a class="button secondary" href="#tabell">Jämför modeller</a>
						</div>
					</div>
					<div class="product-shot">
						<img src="/static/images/1.jpg" alt="CLEVO L10 PRO robotdammsugare med basstation" />
					</div>
				</div>
			</section>

			<section class="stat-band">
				<div class="container wide stat-grid">
					<div>
						<span>Modeller testade</span>
						<strong>7</strong>
						<small>Modeller som ofta jämförs inför köp</small>
					</div>
					<div class="highlight-stat">
						<span>Testpoäng</span>
						<strong>{winner.score}</strong>
						<small>Starkast sammanvägt resultat</small>
					</div>
					<div>
						<span>Pris</span>
						<strong>{winner.price}</strong>
						<small>Prisnivå för vår rekommendation</small>
					</div>
				</div>
			</section>

			<section class="trust-section">
				<div class="container trust-grid">
					<div><strong>Redaktionellt urval</strong><span>Rankingplatser kan inte köpas</span></div>
					<div><strong>Fakta som går att kontrollera</strong><span>Vi stämmer av pris och specifikationer brett</span></div>
					<div><strong>Vardagliga hinder</strong><span>Mattor, hår, trösklar och sladdar finns med</span></div>
					<div><strong>Öppen intäktsmodell</strong><span>Länkar kan ge ersättning utan att påverka betyget</span></div>
				</div>
			</section>

			<section class="section">
				<div class="container">
					<div class="winner-summary card">
						<div>
							<p class="eyebrow">Redaktionens val</p>
							<h2>{winner.name}</h2>
							<p>{winner.tag}. Prisnivå vid jämförelsen: {winner.price}</p>
						</div>
						<div class="mini-specs">
							<div><span>Batteri</span><strong>{winner.battery} min</strong></div>
							<div><span>Betyg</span><strong>{winner.score}/10</strong></div>
							<div><span>Sugkraft</span><strong>5000 Pa</strong></div>
							<div><span>Ljud</span><strong>≤{winner.noise} dB</strong></div>
						</div>
					</div>
				</div>
			</section>

			<section class="section soft" id="ranking">
				<div class="container">
					<div class="section-header">
						<p class="eyebrow">Rankning</p>
						<h2>Topp 5 robotdammsugare</h2>
						<p>Placeringen bygger på städresultat, prisvärde och hur mycket roboten klarar utan handpåläggning.</p>
					</div>
					<div class="rank-list">
						{
							topFive.map((product, index) => (
								<article class={`rank-card card ${index === 0 ? 'is-winner' : ''}`}>
									{index === 0 && <div class="recommend-badge">Vårt val · bäst balans 2026</div>}
									<div class="rank-top">
										<div class="rank-media">
											<img class="rank-image" src={product.image} alt={`${product.name} produktbild`} />
										</div>
										<div>
											<div class="rank-title">
												<span class="rank-number">{index + 1}</span>
												<h3>{product.name}</h3>
											</div>
											<p>{product.tag}</p>
										</div>
										<div class="rank-score">
											<strong>{product.score.toFixed(1)}</strong>
											<span>{product.price}</span>
											{
												product.link && (
													<a class="price-link" href={product.link} target="_blank" rel="nofollow sponsored noopener">
														Se hos återförsäljare
													</a>
												)
											}
										</div>
									</div>
									<div class="pill-row">
										<span class="pill">{product.battery} min</span>
										<span class="pill">{product.nav}</span>
										<span class="pill">{product.station}</span>
										<span class="pill">{product.noise} dB</span>
									</div>
									{
										index === 0 && (
											<div class="winner-detail">
												<div>
													<h4>Därför lyfter vi fram CLEVO L10 PRO</h4>
													<p>
														Den här modellen får förstaplatsen eftersom den träffar rätt i de
														flesta vardagssituationer. Du får lång batteritid, LiDAR och
														självtömning utan att betala för funktioner som många hushåll
														sällan använder.
													</p>
												</div>
												<div class="winner-spec-grid">
													<div><span>Produktnamn</span><strong>CLEVO L10 PRO</strong></div>
													<div><span>Navigering</span><strong>LDS lasernavigering</strong></div>
													<div><span>Batterikapacitet</span><strong>2550 mAh</strong></div>
													<div><span>Batteritid</span><strong>180 min</strong></div>
													<div><span>Sugkraft robot</span><strong>5000 Pa</strong></div>
													<div><span>Sugeffekt station</span><strong>20000 Pa</strong></div>
													<div><span>Vattentank</span><strong>330 ml</strong></div>
													<div><span>Dammpåse</span><strong>3 L</strong></div>
												</div>
											</div>
										)
									}
									<div class="pros-grid">
										<div>
											<h4>Fördelar</h4>
											<ul>
												{product.pros.map((item) => (
													<li>{item}</li>
												))}
											</ul>
										</div>
										<div>
											<h4>Nackdelar</h4>
											<ul>
												{product.cons.map((item) => (
													<li>{item}</li>
												))}
											</ul>
										</div>
									</div>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section class="section" id="tabell">
				<div class="container wide">
					<div class="section-header">
						<p class="eyebrow">Jämförelse</p>
						<h2>Alla modeller i samma översikt</h2>
						<p>På mobil kan tabellen scrollas i sidled för att visa fler uppgifter.</p>
					</div>
					<div class="table-wrap">
						<table>
							<thead>
								<tr>
									<th>Modell</th>
									<th>Pris</th>
									<th>Navigering</th>
									<th>Batteritid</th>
									<th>Moppning</th>
									<th>Fjärrkontroll</th>
									<th>No-Mop zoner</th>
									<th>Ljud</th>
									<th>Hårfri</th>
									<th>Tömningsstation</th>
									<th>Prisvärdhet</th>
								</tr>
							</thead>
							<tbody>
								{
									products.map((product) => (
										<tr>
											<td>
												<strong>{product.name}</strong>
											</td>
											<td>{product.price}</td>
											<td>{product.nav}</td>
											<td>{product.battery} min</td>
											<td>{checked(product.mop)}</td>
											<td>{checked(product.remote)}</td>
											<td>{checked(product.noMop)}</td>
											<td>{product.noise} dB</td>
											<td>{checked(product.hair)}</td>
											<td>{product.station}</td>
											<td>{product.value}</td>
										</tr>
									))
								}
							</tbody>
						</table>
					</div>
				</div>
			</section>

			<section class="section soft">
				<div class="container">
					<div class="section-header">
						<p class="eyebrow">Varför CLEVO L10 PRO hamnar högst</p>
						<h2>Det är helheten som gör skillnaden</h2>
					</div>
					<div class="reason-grid">
						<article class="reason-card card">
							<h3>Mer nytta än priset antyder</h3>
							<p>Självtömning, LiDAR och moppning finns med utan att kostnaden närmar sig de dyraste dockorna.</p>
						</article>
						<article class="reason-card card">
							<h3>Klarar större ytor</h3>
							<p>Batteritiden räcker för fler rum innan roboten måste avbryta och ladda.</p>
						</article>
						<article class="reason-card card">
							<h3>Färre småmoment efteråt</h3>
							<p>Automatisk tömning gör att du inte behöver öppna roboten efter varje körning.</p>
						</article>
						<article class="reason-card card">
							<h3>Säkrare ruttplanering</h3>
							<p>LiDAR ger jämn kartläggning även när ljuset i rummet inte är optimalt.</p>
						</article>
					</div>
				</div>
			</section>

			<section class="section">
				<div class="container">
					<div class="section-header">
						<p class="eyebrow">Små detaljer med praktisk effekt</p>
						<h2>Funktioner som märks när roboten används ofta</h2>
					</div>
					<div class="feature-grid">
						<article class="reason-card card">
							<h3>Fjärrkontroll medföljer</h3>
							<p>Starta, stoppa eller styra utan att alltid behöva gå via appen.</p>
						</article>
						<article class="reason-card card">
							<h3>Stör-ej för stationen</h3>
							<p>Undvik att basstationen tömmer på tider då ljudet stör mest.</p>
						</article>
						<article class="reason-card card">
							<h3>Snabb zonstädning</h3>
							<p>Rikta städningen mot hallen, köket eller en annan mindre yta när olyckan är framme.</p>
						</article>
					</div>
				</div>
			</section>

			<section class="section soft">
				<div class="container wide">
					<div class="section-header">
						<p class="eyebrow">Mot dyrare alternativ</p>
						<h2>Där prisskillnaden blir svår att motivera</h2>
					</div>
					<div class="compare-grid">
						<div class="compare-card card">
							<h3>Clevo vs Roborock S8 MaxV Ultrasvart</h3>
							<table>
								<tbody>
									<tr><th>Pris</th><td>5 179,90 kr</td><td>11 749,00 kr</td></tr>
									<tr><th>Batteritid</th><td>180 min</td><td>180 min</td></tr>
									<tr><th>Fjärrkontroll</th><td>✓</td><td>—</td></tr>
									<tr><th>Ljud</th><td>≤60 dB</td><td>63 dB</td></tr>
								</tbody>
							</table>
							<p>Roborock är mer påkostad, men i batteritid och ljudnivå är skillnaden inte lika övertydlig som priset antyder.</p>
						</div>
						<div class="compare-card card">
							<h3>Clevo vs Philips 7000 Aqua XU7100/02</h3>
							<table>
								<tbody>
									<tr><th>Pris</th><td>5 179,90 kr</td><td>11 499,00 kr</td></tr>
									<tr><th>Batteritid</th><td>180 min</td><td>120 min</td></tr>
									<tr><th>No-Mop zoner</th><td>✓</td><td>—</td></tr>
									<tr><th>Ljud</th><td>≤60 dB</td><td>64 dB</td></tr>
								</tbody>
							</table>
							<p>Philips ger en modern känsla, men den kortare driftstiden och fler vardagskompromisser drar ned helheten.</p>
						</div>
					</div>
				</div>
			</section>

			<section class="section">
				<div class="container article-copy">
					<div class="author-row">
						<img src="/static/images/anders-nilsson.jpg" alt="Anders Nilsson" />
						<div>
							<p class="eyebrow">Testat under jämförbara förhållanden</p>
							<h2>Så genomfördes genomgången</h2>
						</div>
					</div>
					<div class="article-grid">
						<div>
							<h3>Utgångspunkten</h3>
							<p>
								Frågan var enkel: behöver en robotdammsugare kosta över tio tusen kronor för att
								fungera bra i ett vanligt hem? Därför fick sju modeller städa samma ytor, med
								samma typ av smuts och hinder.
							</p>
							<h3>Det vi tittade på</h3>
							<ul>
								<li>Parkett, klinker och tjockare matta ingick i underlaget</li>
								<li>Hår, ris, sand och flingor användes som vardagssmuts</li>
								<li>Sladdar, trösklar och stolsben visade hur navigeringen klarade hinder</li>
								<li>Moppningen prövades på intorkade fläckar på hårt golv</li>
							</ul>
						</div>
						<div>
							<h3>Det vi lade märke till</h3>
							<p>
								Det var inte alltid den mest avancerade roboten som var mest bekväm att leva med.
								Flera modeller krävde mer hjälp än väntat. CLEVO L10 PRO stack ut genom att hålla
								en jämn nivå och snabbt bli en del av städrutinen.
							</p>
							<h3>Särskilt intressant för</h3>
							<ul>
								<li>Hem med husdjur, hår och flera typer av golv</li>
								<li>Boenden där roboten behöver klara många kvadratmeter per körning</li>
								<li>Köpare som vill ha självtömning utan att gå upp i premiumpris</li>
							</ul>
						</div>
					</div>
				</div>
			</section>

			<section class="section soft">
				<div class="container">
					<div class="section-header">
						<p class="eyebrow">Mätvärden</p>
						<h2>Skillnaderna som syns i siffrorna</h2>
					</div>
					<div class="chart-grid">
						<div class="chart-card card">
							<h3>Ljudnivå (dB)</h3>
							<p class="chart-note">Stapeln följer dB-värdet. Kortare stapel betyder tystare modell.</p>
							{products.map((product) => (
								<div class="bar-row">
									<span>{product.name}</span>
									<div><i style={`width: ${noiseValueWidth(product.noise)}%`}></i></div>
									<strong>{product.noise}</strong>
								</div>
							))}
						</div>
						<div class="chart-card card">
							<h3>Batteritid (min)</h3>
							<p class="chart-note">Längre stapel betyder längre batteritid.</p>
							{products.map((product) => (
								<div class="bar-row">
									<span>{product.name}</span>
									<div><i style={`width: ${(product.battery / 180) * 100}%`}></i></div>
									<strong>{product.battery}</strong>
								</div>
							))}
						</div>
						<div class="chart-card card">
							<h3>Pris vs. betyg</h3>
							<p class="chart-note">Stapeln visar testbetyg, inte pris.</p>
							{products.map((product) => (
								<div class="bar-row score-row">
									<span>{product.name}</span>
									<div><i style={`width: ${product.score * 10}%`}></i></div>
									<strong>{product.score.toFixed(1)}</strong>
								</div>
							))}
						</div>
					</div>
				</div>
			</section>

			<section class="section">
				<div class="container">
					<div class="section-header">
						<p class="eyebrow">Efter en tids användning</p>
						<h2>Så beskriver köpare vardagen med roboten</h2>
					</div>
					<div class="testimonial-grid">
						<blockquote class="card">
							<p>
								"Priset fick mig att prova, men det bästa är hur lite den kräver. Den kör när den
